//=== DESTROYER QUANTUM V28.06 — TEST: Max Total Risk Boost ===
// VENI VIDI VICI
// Tests: MaxTotalRisk_Percent 12.0 → 15.0 (+25%)
// Starting from AGGRESSIVE baseline — ONLY this parameter changed.
// Rationale: CRITICAL impact — total risk cap determines max portfolio
// exposure. At 12%, the EA caps out early. At 15%, it has 25% more
// headroom to open additional positions and let winners run.
// This is the ceiling that limits all other risk params.
// Target: Push from $68K toward $75K+
//
//=== CORE RISK ===
InpBase_Risk_Percent=1.5
InpBase_Risk_Percent_H1=0.4
InpDefensiveDD_Percent=20.0
InpDrawdown_Risk_Mult=0.4
InpMaxOpenTrades=16
InpMaxLotSize=8.0
InpMaxTotalRisk_Percent=15.0
InpMaxRiskPerTrade=0.8
//
//=== LEVIATHAN ===
InpLeviathan_KellyFraction=0.35
InpLeviathan_MaxRisk=7.0
InpLeviathan_MinRisk=0.75
//
//=== QUEEN SAFETY ===
InpQueen_MaxDrawdownPct=7.0
InpQueen_MaxExposureLots=2.0
InpQueen_ReaperDDKillPct=4.0
InpQueen_MaxConcurrentBaskets=3
InpHades_BasketStopLoss_Percent=3.5
//
//=== MEAN REVERSION (Looser for more signals) ===
InpMR_BB_Dev=1.7
InpMR_RSI_OB=58.0
InpMR_RSI_OS=42.0
InpMR_ADX_Threshold=18.0
InpMinTQSForEntry=0.25
//
//=== REAPER GRID (Aggressive) ===
